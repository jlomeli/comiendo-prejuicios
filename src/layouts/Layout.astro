---
import "../index.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Comiendo Prejuicios — Terapia · CBT · Trastornos alimentarios · Trauma",
	description = "Terapia con CBT especializada en trastornos alimentarios, trauma y espacios neurodivergente-friendly. Consulta gratuita. Comiendo Prejuicios.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;1,9..144,300&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
	</head>
	<body>
		<slot />
	</body>
</html>
